# Normalize line endings repo-wide. Tree lives on /mnt/c and is edited by both
# Windows-native tools (idf.py, VS Code) and WSL — without this, EOL churn recurs.
# Default: auto-detect text, store and check out as LF (Windows-native build handles LF).
* text=auto eol=lf

# Firmware / C++ sources
*.c    text eol=lf
*.h    text eol=lf
*.hpp  text eol=lf
*.cpp  text eol=lf
*.cc   text eol=lf
*.ino  text eol=lf

# Web frontend / JS-TS
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf

# Config / data / docs
*.json  text eol=lf
*.css   text eol=lf
*.scss  text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.txt   text eol=lf
*.csv   text eol=lf
*.cmake text eol=lf
*.py    text eol=lf
*.sh    text eol=lf
CMakeLists.txt text eol=lf
*.env   text eol=lf

# Windows batch scripts keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets (never normalize)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.bin   binary
*.elf   binary
*.map   binary
*.a     binary
*.o     binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
